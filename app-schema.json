{
  "name": "一抹金蓝自动审片系统",
  "needAuth": false,
  "tables": [
    {
      "tableName": "projects",
      "description": "审片项目表 — 每个项目包含一个剧本+成片的审核任务",
      "columns": [
        {
          "columnName": "id",
          "columnType": "INT",
          "columnComment": "主键ID",
          "isRequired": true,
          "isPrimary": true,
          "isShow": true
        },
        {
          "columnName": "project_name",
          "columnType": "VARCHAR(255)",
          "columnComment": "项目名称",
          "isRequired": true,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "script_file",
          "columnType": "files",
          "columnComment": "剧本文件（上传的剧本文档）",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "video_file",
          "columnType": "videos",
          "columnComment": "成片视频文件",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "status",
          "columnType": "VARCHAR(50)",
          "columnComment": "审核状态：pending待审核 / reviewing审核中 / ai_doneAI完成 / completed已完成",
          "isRequired": true,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "overall_score",
          "columnType": "DECIMAL",
          "columnComment": "总体评分（0-100）",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "total_scenes",
          "columnType": "INT",
          "columnComment": "总场景数",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "pass_count",
          "columnType": "INT",
          "columnComment": "通过数",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "warning_count",
          "columnType": "INT",
          "columnComment": "警告数",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "fail_count",
          "columnType": "INT",
          "columnComment": "不通过数",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "summary_report",
          "columnType": "FULLTEXT",
          "columnComment": "AI审核总结报告（JSON格式，含整体评价、主要问题列表）",
          "isRequired": false,
          "isPrimary": false,
          "isShow": false
        },
        {
          "columnName": "reviewer_notes",
          "columnType": "FULLTEXT",
          "columnComment": "人工审核备注",
          "isRequired": false,
          "isPrimary": false,
          "isShow": false
        },
        {
          "columnName": "created_at",
          "columnType": "DATETIME",
          "columnComment": "创建时间",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "updated_at",
          "columnType": "DATETIME",
          "columnComment": "更新时间",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        }
      ]
    },
    {
      "tableName": "scenes",
      "description": "场景审核结果表 — 每个场景的逐帧审核结果",
      "columns": [
        {
          "columnName": "id",
          "columnType": "INT",
          "columnComment": "主键ID",
          "isRequired": true,
          "isPrimary": true,
          "isShow": true
        },
        {
          "columnName": "project_id",
          "columnType": "quote",
          "columnComment": "关联项目ID",
          "isRequired": true,
          "isPrimary": false,
          "isShow": true,
          "referenceTableName": "projects",
          "showName": "project_name"
        },
        {
          "columnName": "scene_index",
          "columnType": "INT",
          "columnComment": "场景序号",
          "isRequired": true,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "script_text",
          "columnType": "FULLTEXT",
          "columnComment": "剧本对应场景描述",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "frame_url",
          "columnType": "VARCHAR(1024)",
          "columnComment": "提取的关键帧图片URL",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "consistency_score",
          "columnType": "DECIMAL",
          "columnComment": "剧本画面一致性评分（0-100）",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "quality_issues",
          "columnType": "FULLTEXT",
          "columnComment": "画面质量问题列表（JSON数组，如模糊、黑屏、花屏等）",
          "isRequired": false,
          "isPrimary": false,
          "isShow": false
        },
        {
          "columnName": "ai_comment",
          "columnType": "FULLTEXT",
          "columnComment": "AI审核评语",
          "isRequired": false,
          "isPrimary": false,
          "isShow": false
        },
        {
          "columnName": "status",
          "columnType": "VARCHAR(20)",
          "columnComment": "审核结果：pass/warning/fail",
          "isRequired": true,
          "isPrimary": false,
          "isShow": true
        },
        {
          "columnName": "created_at",
          "columnType": "DATETIME",
          "columnComment": "创建时间",
          "isRequired": false,
          "isPrimary": false,
          "isShow": true
        }
      ]
    }
  ]
}
